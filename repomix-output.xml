@pytest.mark.asyncio
async def test_pending_approvals_snapshot_maps_rows() -> None:
    approval_id = uuid4()
    board_id = uuid4()
    organization_id = uuid4()
    task_id = uuid4()
    created_at = datetime(2026, 3, 4, 12, 0, 0)
    approval = Approval(
