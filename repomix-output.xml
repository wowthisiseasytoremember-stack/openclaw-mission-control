<file path="frontend/src/components/atoms/StatusPill.tsx">
import { Badge } from "@/components/ui/badge";

const STATUS_STYLES: Record<
  string,
  "default" | "outline" | "accent" | "success" | "warning" | "danger"
> = {
  inbox: "outline",
  assigned: "accent",
  in_progress: "warning",
  testing: "accent",
  review: "accent",
  done: "success",
  online: "success",
  busy: "warning",
  provisioning: "warning",
  offline: "outline",
  deleting: "danger",
  updating: "accent",
  // device pairing statuses
  pending: "warning",
  approved: "success",
  revoked: "danger",
};

export function StatusPill({ status }: { status: string }) {
  return (
    <Badge variant={STATUS_STYLES[status] ?? "default"}>
      {status.replaceAll("_", " ")}
    </Badge>
  );
}
