        initialBoardIds={["board-1"]}
        boards={[buildBoard()]}
        boardsLoading={false}
        boardsError={null}
        isSubmitting={false}
        submitLabel="Save changes"
        submittingLabel="Saving..."
        submitErrorFallback="Failed to update custom field."
        onSubmit={vi.fn().mockResolvedValue(undefined)}
      />,
